SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C0AU9MLNUCC # Test Chatbot
# Bon Appétit /cafe/YYYY-MM-DD/ 형식: {date} 는 MENU_DATE_TZ(기본 America/Los_Angeles) 기준 오늘 날짜로 치환됩니다.
TARGET_URL=https://sra.cafebonappetit.com/cafe/{date}/
# 스크래핑할 daypart: bonappetit.com HTML의 <section id="..."> (기본 lunch). URL의 #lunch 해시는 서버에 전달되지 않음.
MENU_DAYPART=lunch
